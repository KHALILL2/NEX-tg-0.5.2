# ═══════════════════════════════════════════════════════════════════════════════
# Gate Access Monitoring System — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to  config.env  and fill in your values:
#     cp config.env.example config.env
#
# Then either:
#   • source it before running:   set -a; source config.env; set +a; python gate.py
#   • or load it from the systemd service (see gate-scanner.service)
#
# IMPORTANT: After creating config.env, restrict permissions:
#     chmod 600 config.env
#
# Lines starting with # are comments.  Blank lines are ignored.
# ═══════════════════════════════════════════════════════════════════════════════

# ── API ──────────────────────────────────────────────────────────────────────
# REST endpoint the RPi calls to verify a scanned card.
# Defaults to the BATU production server if not set — override here for staging/dev.
GATE_API_URL=https://batu-gate.alnzam.online/api/v1/gate/check-access

# Optional Bearer token.  If set, sent as:  Authorization: Bearer <key>
GATE_API_KEY=

# The JSON field name used to send the card UID to the API.
# The backend expects "bar_code" — change only if the API endpoint changes.
GATE_API_UID_FIELD=bar_code

# Request timeout in seconds.
GATE_API_TIMEOUT=8

# Number of retry attempts for transient failures (timeout, 5xx).
GATE_API_MAX_RETRIES=3

# Base delay between retries (exponential backoff: 1s, 2s, 4s, …).
GATE_API_RETRY_DELAY=1

# HTTP connection pool size for high-throughput scanning.
GATE_API_POOL_SIZE=10

# ── SSL / TLS ────────────────────────────────────────────────────────────────
# Set to "false" to disable SSL certificate verification (NOT recommended).
GATE_VERIFY_SSL=true

# Path to a CA bundle or self-signed certificate file for certificate pinning.
# Leave blank to use the system default CA bundle.
GATE_API_CERT_PATH=

# ── Media ────────────────────────────────────────────────────────────────────
# Base URL prepended to relative student photo paths returned by the API.
BASE_MEDIA_URL=https://batu-gate.alnzam.online

# ── Arduino Mega / Gate Controller ───────────────────────────────────────────
# Serial port where the Arduino Mega (gate controller) is connected.
GATE_SERIAL_PORT=/dev/ttyUSB0

# Baud rate — must match the Arduino sketch (default 9600).
GATE_BAUD_RATE=9600

# How many seconds the gate stays open before auto-closing.
GATE_OPEN_DURATION=5

# ── RFID / NFC Reader ───────────────────────────────────────────────────────
# Reader type: RC522, PN532, or SIMULATION.
RFID_READER_TYPE=RC522

# RC522 SPI configuration (default: bus 0, device 0, GPIO RST pin 25).
RC522_RST_PIN=25
RC522_SPI_BUS=0
RC522_SPI_DEVICE=1  # Changed to 1 (CE1) to bypass a potentially dead CE0 pin

# Card debounce: minimum seconds between accepting the same card twice.
# Prevents double-taps from opening the gate twice.
CARD_DEBOUNCE_SECONDS=3.0

# ── Security ─────────────────────────────────────────────────────────────────
# ** STRONGLY RECOMMENDED ** — Replace with your own key generated on the RPi:
#     openssl rand -hex 32
# This default key is for development only. Never share it.
UID_HASH_KEY=7f3a9c1e2b4d5f6a8e0c2d4b6f8a0c2e4d6f8a0b2c4e6f8a0b2c4d6f8a0b2c4

# ── Simulation Mode ──────────────────────────────────────────────────────────
# Enable simulation mode for development without physical RFID hardware.
# Auto-generates fake card UIDs at configurable intervals.
SIMULATION_MODE=false

# Interval (seconds) between simulated card reads.
SIMULATION_INTERVAL_SECONDS=3

# Fraction of simulated scans that result in "access granted".
# Remaining: ~15% denied, ~5% errors.
SIMULATION_SUCCESS_RATE=0.8

# ── Offline Fallback Cache ───────────────────────────────────────────────────
# When enabled, the system caches recent *successful* access checks.
# If the API becomes unreachable, cached students can still pass through
# within the TTL window.  All offline-granted entries are logged with a
# hashed UID for auditing.
GATE_OFFLINE_MODE=false

# Time-to-live (seconds) for offline cache entries.
GATE_OFFLINE_CACHE_TTL=300

# ── Health Check ─────────────────────────────────────────────────────────────
# Set to a non-zero port to expose an HTTP /health endpoint for monitoring.
# Example:  curl http://localhost:8080/health
# Set to 0 (default) to disable.
GATE_HEALTH_PORT=0
